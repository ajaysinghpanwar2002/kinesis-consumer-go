          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "alias": "released",
          "query": "SELECT sum(\"value\") FROM \"kinesis_consumer_lease_released\" WHERE (\"stream\" =~ /^$stream$/ AND \"shard\" =~ /^$shard$/) AND $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "alias": "release failures",
          "query": "SELECT sum(\"value\") FROM \"kinesis_consumer_lease_release_failures\" WHERE (\"stream\" =~ /^$stream$/ AND \"shard\" =~ /^$shard$/) AND $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        },
        {
          "alias": "renewals",
